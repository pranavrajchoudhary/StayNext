<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Owner Dashboard | StayNest</title>

<link rel="preconnect" href="https://fonts.googleapis.com">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{

margin:0;

padding:0;

box-sizing:border-box;

font-family:'Poppins',sans-serif;

}

body{

background:#f5f7fa;

color:#333;

}

.container{

max-width:1300px;

margin:auto;

padding:25px;

}

.header{

display:flex;

justify-content:space-between;

align-items:center;

gap:20px;

margin-bottom:30px;

flex-wrap:wrap;

}

.header-left h1{

font-size:32px;

margin-bottom:8px;

color:#222;

}

.header-left p{

color:#666;

}

.add-btn{

background:#ff5a3d;

color:white;

padding:12px 22px;

text-decoration:none;

border-radius:8px;

font-weight:600;

transition:.25s;

}

.add-btn:hover{

background:#eb4b2d;

}

.cards{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(230px,1fr));

gap:18px;

margin-bottom:30px;

}

.card{

background:white;

padding:22px;

border-radius:15px;

box-shadow:0 8px 25px rgba(0,0,0,.08);

transition:.25s;

}

.card:hover{

transform:translateY(-3px);

}

.card h4{

font-size:15px;

font-weight:500;

color:#777;

margin-bottom:10px;

}

.card h2{

font-size:30px;

color:#ff5a3d;

}

.card small{

display:block;

margin-top:10px;

color:#888;

}

.section{

background:white;

padding:25px;

border-radius:15px;

box-shadow:0 8px 25px rgba(0,0,0,.08);

margin-bottom:28px;

}

.section-title{

font-size:23px;

margin-bottom:20px;

color:#222;

}

.task{

padding:15px;

border-left:5px solid #ff5a3d;

background:#fff8f6;

margin-bottom:15px;

border-radius:8px;

}

.task:last-child{

margin-bottom:0;

}

.booking-grid{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(320px,1fr));

gap:18px;

}

.booking-card{

background:#fafafa;

border:1px solid #ececec;

border-radius:12px;

padding:18px;

transition:.25s;

}

.booking-card:hover{

box-shadow:0 6px 18px rgba(0,0,0,.08);

}

.booking-card h3{

margin-bottom:12px;

font-size:20px;

color:#222;

}

.booking-info{

display:grid;

grid-template-columns:1fr 1fr;

gap:10px;

margin-top:12px;

}

.booking-info div{

background:white;

padding:10px;

border-radius:8px;

font-size:14px;

}

.status{

display:inline-block;

padding:6px 14px;

border-radius:30px;

font-size:13px;

font-weight:600;

margin-top:15px;

text-transform:capitalize;

}

.paid{

background:#d4f6dd;

color:#116b2b;

}

.pending{

background:#fff4d3;

color:#9a6b00;

}

.cancelled{

background:#ffe0e0;

color:#b31b1b;

}

.properties{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(350px,1fr));

gap:20px;

}

.property-card{

border:1px solid #ececec;

border-radius:15px;

overflow:hidden;

background:white;

transition:.25s;

}

.property-card:hover{

transform:translateY(-3px);

box-shadow:0 10px 22px rgba(0,0,0,.08);

}

.property-card img{

width:100%;

height:220px;

object-fit:cover;

}

.property-content{

padding:18px;

}

.property-content h3{

margin-bottom:10px;

}

.property-content p{

color:#666;

margin-bottom:8px;

}

.actions{

display:flex;

gap:10px;

margin-top:18px;

flex-wrap:wrap;

}

.btn{

flex:1;

text-align:center;

padding:11px;

text-decoration:none;

border-radius:8px;

font-weight:600;

}

.btn-view{

background:#ff5a3d;

color:white;

}

.btn-edit{

background:#2d6cdf;

color:white;

}

.calculator{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(220px,1fr));

gap:18px;

margin-top:18px;

}

.calculator input{

width:100%;

padding:12px;

border:1px solid #ddd;

border-radius:8px;

outline:none;

}

.calculate-btn{

margin-top:20px;

padding:12px;

width:100%;

border:none;

background:#ff5a3d;

color:white;

font-size:16px;

font-weight:600;

border-radius:8px;

cursor:pointer;

}

.calculate-btn:hover{

background:#eb4b2d;

}

.result{

margin-top:18px;

padding:18px;

background:#fff8f6;

border-radius:10px;

font-size:17px;

font-weight:600;

display:none;

}

@media(max-width:768px){

.container{

padding:16px;

}

.header{

flex-direction:column;

align-items:flex-start;

}

.cards{

grid-template-columns:1fr;

}

.booking-grid{

grid-template-columns:1fr;

}

.properties{

grid-template-columns:1fr;

}

.actions{

flex-direction:column;

}

.btn{

width:100%;

}

.booking-info{

grid-template-columns:1fr;

}

}

</style>

</head>

<body>

<%- include("../partials/navbar.ejs") %>

<div class="container">

<div class="header">

<div class="header-left">

<h1>

Welcome, <%= currUser.username %>

</h1>

<p>

Manage your properties, bookings and daily business from one place.

</p>

</div>

<a href="/listings/new" class="add-btn">

+ Add New Property

</a>

</div>

<div class="cards">

<div class="card">

<h4>

My Properties

</h4>

<h2>

<%= listings.length %>

</h2>

<small>

Total properties registered

</small>

</div>

<div class="card">

<h4>

Bookings

</h4>

<h2>

<%= orders.length %>

</h2>

<small>

Total customer bookings

</small>

</div>

<div class="card">

<h4>

Pending

</h4>

<h2>

<%= pendingBookings.length %>

</h2>

<small>

Need your attention

</small>

</div>

<div class="card">

<h4>

Revenue

</h4>

<h2>

₹ <%= totalRevenue %>

</h2>

<small>

Total earnings

</small>

</div>

</div>
<div class="section">

<h2 class="section-title">

Today's Tasks

</h2>

<% if(arrivalsToday.length===0 && pendingBookings.length===0){ %>

<div class="task">

Everything looks good today. No guest arrivals or pending bookings.

</div>

<% } %>

<% arrivalsToday.forEach(function(order){ %>

<div class="task">

<strong>Guest Arrival</strong><br>

Property:
<b><%= order.listing.title %></b>

<br>

Check-in:
<%= new Date(order.fromDate).toLocaleDateString("en-IN") %>

</div>

<% }) %>

<% pendingBookings.forEach(function(order){ %>

<div class="task">

<strong>Pending Booking</strong><br>

Property:
<b><%= order.listing.title %></b>

<br>

Booking Amount:
₹ <%= order.totalFare %>

</div>

<% }) %>

</div>



<div class="section">

<h2 class="section-title">

Recent Bookings

</h2>

<% if(orders.length===0){ %>

<p>

No bookings available yet.

</p>

<% } %>

<div class="booking-grid">

<% orders.slice(0,6).forEach(function(order){ %>

<div class="booking-card">

<h3>

<%= order.listing.title %>

</h3>

<div class="booking-info">

<div>

<strong>Check In</strong>

<br>

<%= new Date(order.fromDate).toLocaleDateString("en-IN") %>

</div>

<div>

<strong>Check Out</strong>

<br>

<%= new Date(order.toDate).toLocaleDateString("en-IN") %>

</div>

<div>

<strong>Guests</strong>

<br>

<%= order.guests %>

</div>

<div>

<strong>Amount</strong>

<br>

₹ <%= order.totalFare %>

</div>

</div>

<div style="margin-top:15px;">

<strong>Contact</strong>

<br>

<%= order.phone || "Not Provided" %>

</div>

<div style="margin-top:12px;">

<strong>Email</strong>

<br>

<%= order.email || "Not Provided" %>

</div>

<% if(order.requests){ %>

<div style="margin-top:12px;">

<strong>Special Request</strong>

<br>

<%= order.requests %>

</div>

<% } %>

<span class="status <%= order.status %>">

<%= order.status %>

</span>

</div>

<% }) %>

</div>

</div>
<div class="section">

<h2 class="section-title">

My Properties

</h2>

<% if(listings.length===0){ %>

<p>

You haven't added any property yet.

</p>

<a href="/listings/new" class="add-btn">

Add First Property

</a>

<% } %>

<div class="properties">

<% listings.forEach(function(listing){ %>

<div class="property-card">

<img
src="<%= listing.image.url %>"
alt="<%= listing.title %>">

<div class="property-content">

<h3>

<%= listing.title %>

</h3>

<p>

<strong>Location</strong>

<br>

<%= listing.location %>, <%= listing.country %>

</p>

<p>

<strong>Price</strong>

<br>

₹ <%= listing.price %> / Night

</p>

<p>

<strong>Description</strong>

<br>

<%= listing.description.substring(0,120) %>...

</p>

<div class="actions">

<a
href="/listings/<%= listing._id %>"
class="btn btn-view">

View

</a>

<a
href="/listings/<%= listing._id %>/edit"
class="btn btn-edit">

Edit

</a>

</div>

</div>

</div>

<% }) %>

</div>

</div>





<div class="section">

<h2 class="section-title">

Quick Business Calculator

</h2>

<p style="color:#666;margin-bottom:20px;">

Estimate the final amount after GST and discount before sharing the price with guests.

</p>

<div class="calculator">

<div>

<label>

Base Amount (₹)

</label>

<input
type="number"
id="baseAmount"
placeholder="5000">

</div>

<div>

<label>

GST (%)

</label>

<input
type="number"
id="gst"
value="18">

</div>

<div>

<label>

Discount (%)

</label>

<input
type="number"
id="discount"
value="0">

</div>

<div>

<label>

Advance Received (₹)

</label>

<input
type="number"
id="advance"
value="0">

</div>

</div>

<button
class="calculate-btn"
onclick="calculateBusiness()">

Calculate

</button>

<div
class="result"
id="resultBox">

</div>

</div>
<script>

function calculateBusiness(){

    const base = parseFloat(document.getElementById("baseAmount").value) || 0;

    const gst = parseFloat(document.getElementById("gst").value) || 0;

    const discount = parseFloat(document.getElementById("discount").value) || 0;

    const advance = parseFloat(document.getElementById("advance").value) || 0;

    const gstAmount = (base * gst) / 100;

    const amountAfterGST = base + gstAmount;

    const discountAmount = (amountAfterGST * discount) / 100;

    const finalAmount = amountAfterGST - discountAmount;

    const remaining = finalAmount - advance;

    const result = document.getElementById("resultBox");

    result.style.display = "block";

    result.innerHTML = `

        <div style="line-height:2;">

            <strong>Quotation Summary</strong>

            <hr style="margin:10px 0;">

            Base Amount :
            <strong>₹ ${base.toFixed(2)}</strong>

            <br>

            GST (${gst}%):
            <strong>₹ ${gstAmount.toFixed(2)}</strong>

            <br>

            Amount After GST :
            <strong>₹ ${amountAfterGST.toFixed(2)}</strong>

            <br>

            Discount (${discount}%):
            <strong>- ₹ ${discountAmount.toFixed(2)}</strong>

            <br>

            <hr style="margin:10px 0;">

            Final Amount :
            <strong style="color:#ff5a3d;font-size:20px;">

                ₹ ${finalAmount.toFixed(2)}

            </strong>

            <br><br>

            Advance Received :
            <strong>

                ₹ ${advance.toFixed(2)}

            </strong>

            <br>

            Remaining Amount :
            <strong style="color:green;">

                ₹ ${remaining.toFixed(2)}

            </strong>

        </div>

    `;

}

</script>

<%- include("../partials/footer.ejs") %>

</div>

</body>

</html>