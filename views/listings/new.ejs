<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Add Property | StayNest</title>

    <link rel="stylesheet" href="/new.css">

    <link rel="icon" href="/staynesticon.png" type="image/x-icon">

    <style>

        body{

            background:#f7f7f7;

        }

        .page{

            max-width:1100px;
            margin:40px auto;
            padding:0 20px;

        }

        .page-title{

            text-align:center;
            margin-bottom:35px;

        }

        .page-title h1{

            font-size:38px;
            margin-bottom:10px;

        }

        .page-title p{

            color:#666;
            font-size:17px;

        }

        .ai-card{

            background:#ffffff;

            border-radius:18px;

            padding:30px;

            margin-bottom:35px;

            box-shadow:0 10px 30px rgba(0,0,0,.08);

            border-left:5px solid #ff5a3d;

        }

        .ai-card h2{

            margin-bottom:10px;

            color:#ff5a3d;

        }

        .ai-card p{

            color:#666;

            line-height:1.7;

            margin-bottom:25px;

        }

        .generate-btn{

            width:100%;

            padding:15px;

            border:none;

            border-radius:10px;

            cursor:pointer;

            background:#ff5a3d;

            color:white;

            font-size:17px;

            font-weight:600;

            transition:.3s;

        }

        .generate-btn:hover{

            background:#e74d30;

        }

        .loading{

            display:none;

            margin-top:18px;

            color:#ff5a3d;

            font-weight:600;

        }

        .form-container{

            background:#fff;

            padding:35px;

            border-radius:18px;

            box-shadow:0 10px 30px rgba(0,0,0,.08);

        }

        .form-container h2{

            margin-bottom:25px;

            color:#222;

        }

    </style>

</head>

<body>

<%- include("../partials/navbar.ejs") %>

<div class="page">

    <div class="page-title">

        <h1>

            Register Your Property

        </h1>

        <p>

            Create a professional StayNest listing in minutes.
            Write naturally in any language and let the AI Listing
            Assistant improve your content before publishing.

        </p>

    </div>

    <div class="ai-card">

        <h2>

            AI Listing Assistant

        </h2>

        <p>

            Simply write your property title and description below.
            Click <strong>Improve Listing with AI</strong> and the assistant
            will rewrite the content professionally, improve grammar,
            optimize readability, and generate suggested amenities,
            house rules and SEO tags.

            You remain in full control and can edit everything before
            publishing your property.

        </p>

        <button
            type="button"
            class="generate-btn"
            id="generateAI">

            Improve Listing with AI

        </button>

        <div
            class="loading"
            id="loadingText">

            Improving your listing...

        </div>

    </div>

    <div class="form-container">

        <h2>

            Property Details

        </h2>

        <form
            action="/listings"
            method="POST"
            enctype="multipart/form-data">
	            <label for="title">

                Property Title

            </label>

            <input
                type="text"
                id="title"
                name="title"
                required
                placeholder="Example: Beautiful Lakeside Farmhouse">


            <label for="description">

                Property Description

            </label>

            <textarea
                id="description"
                name="description"
                rows="8"
                required
                placeholder="Describe your property naturally. You can write in English, Hindi, or any language. The AI assistant will improve it before publishing."></textarea>


            <label for="image">

                Property Image

            </label>

            <input
                type="file"
                id="image"
                name="image"
                accept="image/*">


            <label for="price">

                Price Per Night (₹)

            </label>

            <input
                type="number"
                id="price"
                name="price"
                min="0"
                required
                placeholder="2500">


            <label for="location">

                Location

            </label>

            <input
                type="text"
                id="location"
                name="location"
                required
                placeholder="Goa">


            <label for="country">

                Country

            </label>

            <input
                type="text"
                id="country"
                name="country"
                required
                placeholder="India">


            <!-- AI Generated Data -->

            <input
                type="hidden"
                id="amenities"
                name="amenities">


            <input
                type="hidden"
                id="houseRules"
                name="houseRules">


            <input
                type="hidden"
                id="seoTags"
                name="seoTags">


            <button
                type="submit"
                class="btn-submit">

                Publish Property

            </button>

        </form>

    </div>

</div>

<%- include("../partials/footer.ejs") %>

<script>
const generateBtn = document.getElementById("generateAI");
const loadingText = document.getElementById("loadingText");

generateBtn.addEventListener("click", improveListing);

async function improveListing() {

    const title = document.getElementById("title").value.trim();

    const description = document.getElementById("description").value.trim();

    const location = document.getElementById("location").value.trim();

    const country = document.getElementById("country").value.trim();

    if (description.length < 20) {

        alert("Please write a more detailed property description before using AI.");

        return;

    }

    loadingText.style.display = "block";

    generateBtn.disabled = true;

    generateBtn.innerText = "Improving...";

    try {

        const response = await fetch("/ai/improve-listing", {

            method: "POST",

            headers: {

                "Content-Type": "application/json"

            },

            body: JSON.stringify({

                title,

                description,

                location,

                country

            })

        });

        const result = await response.json();

        if (!result.success) {

            throw new Error(result.message);

        }

        const ai = result.data;

        document.getElementById("title").value = ai.title;

        document.getElementById("description").value = ai.description;

        document.getElementById("amenities").value =
            JSON.stringify(ai.amenities);

        document.getElementById("houseRules").value =
            JSON.stringify(ai.houseRules);

        document.getElementById("seoTags").value =
            JSON.stringify(ai.seoTags);

        let message =
            "AI has successfully improved your listing.\n\n";

        message +=
            "Generated:\n";

        message +=
            "• Professional Title\n";

        message +=
            "• Improved Description\n";

        message +=
            "• Suggested Amenities\n";

        message +=
            "• House Rules\n";

        message +=
            "• SEO Tags\n\n";

        message +=
            "Review everything before publishing.";

        alert(message);

    }

    catch (err) {

        console.error(err);

        alert("Unable to improve the listing. Please try again.");

    }

    finally {

        loadingText.style.display = "none";

        generateBtn.disabled = false;

        generateBtn.innerText = "Improve Listing with AI";

    }

}
</script>

</body>

</html>	